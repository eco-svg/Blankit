/**
 * API Client (No Authentication)
 * Handles all HTTP requests to backend
 */

const API = {
    baseURL: window.location.origin,
    
    /**
     * Get headers
     */
    getHeaders() {
        return {
            'Content-Type': 'application/json'
        };
    },
    
    /**
     * Handle API response
     */
    async handleResponse(response) {
        const data = await response.json();
        
        if (!response.ok) {
            throw new Error(data.error || `HTTP ${response.status}`);
        }
        
        return data;
    },
    
    /**
     * Make API request
     */
    async request(endpoint, options = {}) {
        const url = `${this.baseURL}${endpoint}`;
        const response = await fetch(url, options);
        return await this.handleResponse(response);
    },
    
    // ==================== GOALS ====================
    
    async getGoals() {
        return await this.request('/api/goals', {
            method: 'GET',
            headers: this.getHeaders()
        });
    },
    
    async createGoal(text, priority = 'medium', category = 'personal') {
        return await this.request('/api/goals', {
            method: 'POST',
            headers: this.getHeaders(),
            body: JSON.stringify({ text, priority, category })
        });
    },
    
    async updateGoal(goalId, updates) {
        return await this.request(`/api/goals/${goalId}`, {
            method: 'PUT',
            headers: this.getHeaders(),
            body: JSON.stringify(updates)
        });
    },
    
    async deleteGoal(goalId) {
        return await this.request(`/api/goals/${goalId}`, {
            method: 'DELETE',
            headers: this.getHeaders()
        });
    },
    
    // ==================== STEPS ====================
    
    async getSteps(days = 30) {
        return await this.request(`/api/steps?days=${days}`, {
            method: 'GET',
            headers: this.getHeaders()
        });
    },
    
    async updateSteps(steps) {
        return await this.request('/api/steps', {
            method: 'POST',
            headers: this.getHeaders(),
            body: JSON.stringify({ steps })
        });
    },
    
    // ==================== ALARMS ====================
    
    async getAlarms() {
        return await this.request('/api/alarms', {
            method: 'GET',
            headers: this.getHeaders()
        });
    },
    
    async createAlarm(time, label = null) {
        return await this.request('/api/alarms', {
            method: 'POST',
            headers: this.getHeaders(),
            body: JSON.stringify({ time, label })
        });
    },
    
    async deleteAlarm(alarmId) {
        return await this.request(`/api/alarms/${alarmId}`, {
            method: 'DELETE',
            headers: this.getHeaders()
        });
    },
    
    // ==================== NOTES (ENCRYPTED) ====================
    
    async getNotes(days = 30) {
        return await this.request(`/api/notes?days=${days}`, {
            method: 'GET',
            headers: this.getHeaders()
        });
    },
    
    async saveNote(content, mood = null) {
        return await this.request('/api/notes', {
            method: 'POST',
            headers: this.getHeaders(),
            body: JSON.stringify({ content, mood })
        });
    },
    
    // ==================== SETTINGS ====================
    
    async getSettings() {
        return await this.request('/api/settings', {
            method: 'GET',
            headers: this.getHeaders()
        });
    },
    
    async updateSettings(settings) {
        return await this.request('/api/settings', {
            method: 'PUT',
            headers: this.getHeaders(),
            body: JSON.stringify(settings)
        });
    },
    
    // ==================== HISTORY & STATS ====================
    
    async getHistory(limit = 50) {
        return await this.request(`/api/history?limit=${limit}`, {
            method: 'GET',
            headers: this.getHeaders()
        });
    },
    
    async getStats() {
        return await this.request('/api/stats', {
            method: 'GET',
            headers: this.getHeaders()
        });
    }
};

// Export for use in other modules
if (typeof module !== 'undefined' && module.exports) {
    module.exports = API;
}